#!/bin/bash
# ============================================================
# RavenOS PI5 — Mainsail module install script
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

# Variables are automatically exported by CustomPiOS

# ── System dependencies ──────────────────────────────────────
apt-get update --allow-releaseinfo-change
apt-get install -y --no-install-recommends \
    nginx \
    unzip \
    curl \
    wget

# ── Download latest Mainsail release ─────────────────────────
MAINSAIL_RELEASE_URL=$(curl -sI \
    https://github.com/mainsail-crew/mainsail/releases/latest \
    | grep -i '^location:' \
    | awk '{print $2}' \
    | tr -d '\r')

MAINSAIL_VERSION=$(echo "${MAINSAIL_RELEASE_URL}" | awk -F'/tag/' '{print $2}')

echo "Installing Mainsail ${MAINSAIL_VERSION}"

wget -q \
    "https://github.com/mainsail-crew/mainsail/releases/download/${MAINSAIL_VERSION}/mainsail.zip" \
    -O /tmp/mainsail.zip

mkdir -p ${MAINSAIL_WEBROOT}
unzip -q /tmp/mainsail.zip -d ${MAINSAIL_WEBROOT}
rm /tmp/mainsail.zip

# ── Also keep a copy in pi home for update_manager tracking ──
sudo -u pi mkdir -p ${MAINSAIL_DIR}
sudo -u pi cp -r ${MAINSAIL_WEBROOT}/. ${MAINSAIL_DIR}/

# ── Symlink so nginx serves from the tracked directory ────────
rm -rf ${MAINSAIL_WEBROOT}
ln -s ${MAINSAIL_DIR} ${MAINSAIL_WEBROOT}

# ── Mainsail config.json — Moonraker via nginx on same host (:80) ─
# Hard-coding hostname:7125 breaks when the UI is opened at http://<IP>/ (cross-origin → Moonraker 401/CORS; UI can show 500).
cat > ${MAINSAIL_DIR}/config.json << 'EOF'
{
    "instancesDB": "moonraker",
    "instances": [
        {
            "name": "RavenOS",
            "hostname": "",
            "port": 80,
            "path": "/"
        }
    ],
    "customNavigation": [
        {
            "title": "Configurator",
            "href": "/configure/",
            "target": "_self",
            "position": 82
        }
    ]
}
EOF

# ── nginx config ─────────────────────────────────────────────
cp /filesystem/etc/nginx/sites-available/mainsail \
   /etc/nginx/sites-available/mainsail

rm -f /etc/nginx/sites-enabled/default
ln -sf /etc/nginx/sites-available/mainsail /etc/nginx/sites-enabled/mainsail

# Lay down filesystem/root (helper script, NM dispatcher, nginx drop-in) — same pattern as hotspot.
unpack /filesystem/root /

# ── Root URL: Ethernet → Mainsail, no cable → Configurator ───
mkdir -p /var/lib/ravenos
chmod +x /usr/local/bin/ravenos-update-nginx-root.sh
/usr/local/bin/ravenos-update-nginx-root.sh
systemctl daemon-reload || true

# ── Verify nginx config ───────────────────────────────────────
nginx -t

systemctl_if_exists enable nginx

echo "✅ Mainsail module installed — version ${MAINSAIL_VERSION}"
