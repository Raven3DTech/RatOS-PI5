#!/bin/bash
# ============================================================
# RavenOS PI5 — Configurator module (clone Raven3DTech/RatOS-configurator fork; branch v2.1.x)
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

# Variables are automatically exported by CustomPiOS

# ── Node.js 20 LTS ───────────────────────────────────────────
curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
apt-get install -y --no-install-recommends \
    nodejs \
    git \
    avahi-daemon \
    fonts-inter \
    fonts-dejavu-core

node --version
npm --version

# ── Clone Configurator ───────────────────────────────────────
sudo -u pi git clone \
    ${RATOS_CONFIGURATOR_REPO} \
    ${RATOS_CONFIGURATOR_DIR}

cd ${RATOS_CONFIGURATOR_DIR}
sudo -u pi git checkout ${RATOS_CONFIGURATOR_BRANCH}

# Browser tab / metadata title (upstream says "RatOS Configurator")
LAYOUT="${RATOS_CONFIGURATOR_DIR}/src/app/layout.tsx"
if [[ -f "${LAYOUT}" ]]; then
    sudo -u pi sed -i "s/RatOS Configurator/RavenOS Configurator/g" "${LAYOUT}"
fi

# ── RavenOS favicon + top-bar logo (module filesystem → Next app/public) ─
if [[ -f /filesystem/branding/favicon-32x32.png ]]; then
    sudo -u pi cp /filesystem/branding/favicon-32x32.png "${RATOS_CONFIGURATOR_DIR}/src/app/icon.png"
    sudo -u pi rm -f "${RATOS_CONFIGURATOR_DIR}/src/app/icon.svg"
fi
if [[ -f /filesystem/branding/ravenos-logo.png ]]; then
    sudo -u pi cp /filesystem/branding/ravenos-logo.png "${RATOS_CONFIGURATOR_DIR}/src/public/ravenos-logo.png"
    for f in topmenu.tsx template.tsx; do
        APPF="${RATOS_CONFIGURATOR_DIR}/src/app/${f}"
        if [[ -f "${APPF}" ]]; then
            sudo -u pi sed -i "s|@/public/logo-white\\.svg|@/public/ravenos-logo.png|g" "${APPF}"
        fi
    done
fi

# ── Fix hardcoded paths that assume Raspberry Pi OS defaults ─
# The configurator has bash scripts that hardcode /home/pi.
# Since we use BASE_USER=pi this is fine, but we patch any
# remaining hardcoded strings for robustness.
find ${RATOS_CONFIGURATOR_DIR}/scripts -name "*.sh" \
    -exec sed -i 's|/home/pi|/home/pi|g' {} \; 2>/dev/null || true

# ── Create RatOS config subdirectory ─────────────────────────
sudo -u pi mkdir -p ${RATOS_CONFIG_PATH}

# ── Write .env.local ─────────────────────────────────────────
# Move the environment file to the actual Next.js app directory (src)
cp /filesystem/home/pi/ratos-configurator/.env.local \
   ${RATOS_CONFIGURATOR_DIR}/src/.env.local
chown pi:pi ${RATOS_CONFIGURATOR_DIR}/src/.env.local

# ── Wi-Fi setup (Bookworm): NM needs nmcli; upstream only wrote wpa_supplicant.conf ─
cp /filesystem/home/pi/ratos-configurator-patches/add-wifi-network.sh \
   ${RATOS_CONFIGURATOR_DIR}/src/scripts/add-wifi-network.sh
chmod 755 ${RATOS_CONFIGURATOR_DIR}/src/scripts/add-wifi-network.sh
chown pi:pi ${RATOS_CONFIGURATOR_DIR}/src/scripts/add-wifi-network.sh

# ── Offline-safe fonts (Next.js build in chroot/CI) ───────────
# next/font/google fetches from fonts.gstatic.com at build time — often ETIMEDOUT under qemu chroot.
# Use next/font/local + a system TTF copied into the repo.
sudo -u pi mkdir -p "${RATOS_CONFIGURATOR_DIR}/src/fonts"
FONTPATH=$(dpkg -L fonts-inter 2>/dev/null | grep -E '/Inter-Regular\.ttf$' | head -n1)
[ -z "${FONTPATH}" ] && FONTPATH=$(dpkg -L fonts-inter 2>/dev/null | grep -E '\.ttf$' | head -n1)
if [ ! -f "${FONTPATH}" ]; then
  FONTPATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
fi
sudo -u pi cp -f "${FONTPATH}" "${RATOS_CONFIGURATOR_DIR}/src/fonts/inter.ttf"
sudo -u pi tee "${RATOS_CONFIGURATOR_DIR}/src/app/fonts.tsx" >/dev/null <<'FONTSEOF'
import localFont from 'next/font/local';

// RavenOS PI5: avoid next/font/google (network at build time). Inter TTF from fonts-inter (or DejaVu fallback).
export const inter = localFont({
  src: '../fonts/inter.ttf',
  variable: '--inter-font',
  display: 'swap',
});
FONTSEOF

# ── Next.js behind nginx: stop slash / Location redirect loops ─
# - trailingSlash + skipTrailingSlashRedirect (top-level; not under experimental in Next 14+).
# - Remove stock headers() COOP/COEP (require-corp) — causes client-side exceptions behind nginx/LAN.
sudo -u pi python3 <<PY
from pathlib import Path
import re

def strip_headers_async_block(text: str) -> str:
    m = re.search(r"^\s*headers:\s*async\s*\(\)\s*=>\s*\{", text, re.MULTILINE)
    if not m:
        return text
    start = m.start()
    i = m.end() - 1
    if i >= len(text) or text[i] != "{":
        return text
    depth = 0
    for k in range(i, len(text)):
        if text[k] == "{":
            depth += 1
        elif text[k] == "}":
            depth -= 1
            if depth == 0:
                end = k + 1
                while end < len(text) and text[end] in " \t\r":
                    end += 1
                if end < len(text) and text[end] == ",":
                    end += 1
                return text[:start] + text[end:]
    return text

p = Path("${RATOS_CONFIGURATOR_DIR}/src/next.config.mjs")
t = p.read_text(encoding="utf-8")
needle = "basePath: '/configure',"
if "trailingSlash" not in t and needle in t:
    t = t.replace(needle, needle + "\n\ttrailingSlash: true,", 1)
# Remove legacy patch that put skip under experimental
old_exp = "typedRoutes: true,\n\t\tskipTrailingSlashRedirect: true,\n"
if old_exp in t:
    t = t.replace(old_exp, "typedRoutes: true,\n", 1)
if "skipTrailingSlashRedirect" not in t:
    tl = "\ttrailingSlash: true,"
    if tl in t:
        t = t.replace(tl, tl + "\n\tskipTrailingSlashRedirect: true,", 1)
if "Cross-Origin-Embedder-Policy" in t or "headers: async" in t:
    t2 = strip_headers_async_block(t)
    if t2 != t:
        t = t2
p.write_text(t, encoding="utf-8")
PY

# ── Install pnpm and dependencies ────────────────────────────
npm install -g pnpm
cd ${RATOS_CONFIGURATOR_DIR}/src
sudo -u pi pnpm install

# ── Upstream hardening (v2.1.x): empty printer list / tRPC 500s ─────────────
# - printer.printers sorts with b.description.indexOf — missing description throws.
# - getBoards() throws if any board-definition.json fails Zod parse — breaks getPrinters().
sudo -u pi python3 - "${RATOS_CONFIGURATOR_DIR}" <<'PATCHPY'
from pathlib import Path
import sys

base = Path(sys.argv[1]) / "src" / "server" / "routers"
printer_ts = base / "printer.ts"
mcu_ts = base / "mcu.ts"

if printer_ts.is_file():
    t = printer_ts.read_text(encoding="utf-8")
    old = "b.description.indexOf('Discontinued')"
    new = "(b.description ?? '').indexOf('Discontinued')"
    if old in t and new not in t:
        t = t.replace(old, new, 1)
        printer_ts.write_text(t, encoding="utf-8")
        print("patched printer.ts: description sort guard")
    else:
        print("printer.ts: skip (already patched or upstream changed)")

if mcu_ts.is_file():
    t = mcu_ts.read_text(encoding="utf-8")
    needle = """\t\t\ttry {
\t\t\t\treturn BoardWithDetectionStatus.parse(b);
\t\t\t} catch (e) {
\t\t\t\tthrow new TRPCError({
\t\t\t\t\tcode: 'INTERNAL_SERVER_ERROR',
\t\t\t\t\tmessage: `Invalid board definition for ${b.name} in ${b.path}`,
\t\t\t\t\tcause: e,
\t\t\t\t});
\t\t\t}
\t\t});"""
    repl = """\t\t\ttry {
\t\t\t\treturn BoardWithDetectionStatus.parse(b);
\t\t\t} catch {
\t\t\t\treturn null;
\t\t\t}
\t\t})
\t\t.filter((b): b is BoardWithDetectionStatus => b != null);"""
    if needle in t:
        t = t.replace(needle, repl, 1)
        mcu_ts.write_text(t, encoding="utf-8")
        print("patched mcu.ts: skip invalid board definitions")
    else:
        print("mcu.ts: skip (already patched or upstream changed)")
PATCHPY

# Match project Prettier (heredoc fonts.tsx + patched routers can otherwise fail ESLint during `next build`).
sudo -u pi bash -lc "cd ${RATOS_CONFIGURATOR_DIR}/src && pnpm exec prettier --write app/fonts.tsx app/topmenu.tsx app/template.tsx server/routers/printer.ts server/routers/mcu.ts"

# ── Build the Next.js production app ─────────────────────────
# CI runners are memory-tight; cap Node heap explicitly to reduce OOM during Next build.
sudo -u pi env NODE_OPTIONS="--max-old-space-size=4096" pnpm run build

# ── OS release (Configurator tRPC osVersion: statSync('/etc/ratos-release') throws if missing → HTTP 500) ─
cp /filesystem/etc/ratos-release /etc/ratos-release
chmod 644 /etc/ratos-release

# ── Sudo rules so configurator can flash boards ───────────────
cp /filesystem/etc/sudoers.d/ravenos-flash \
   /etc/sudoers.d/ravenos-flash
chmod 440 /etc/sudoers.d/ravenos-flash
visudo -c -f /etc/sudoers.d/ravenos-flash

# ── Scripts directory ─────────────────────────────────────────
sudo -u pi mkdir -p /home/pi/scripts
cp /filesystem/home/pi/scripts/ravenos-firstboot.sh \
   /home/pi/scripts/ravenos-firstboot.sh
chmod +x /home/pi/scripts/ravenos-firstboot.sh
chown pi:pi /home/pi/scripts/ravenos-firstboot.sh

# ── systemd services ──────────────────────────────────────────
cp /filesystem/etc/systemd/system/ratos-configurator.service \
   /etc/systemd/system/ratos-configurator.service

cp /filesystem/etc/systemd/system/ravenos-firstboot.service \
   /etc/systemd/system/ravenos-firstboot.service

systemctl_if_exists enable ratos-configurator
systemctl_if_exists enable ravenos-firstboot
systemctl_if_exists enable avahi-daemon

echo "✅ Configurator module installed"
