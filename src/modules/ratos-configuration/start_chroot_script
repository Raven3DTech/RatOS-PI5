#!/usr/bin/env bash
# Ship RatOS modular config (boards, macros, templates) for Configurator + Klipper.
# Content is copied from RatOS-configurator's configuration/ subtree (same branch as the app).
# Does NOT run scripts/ratos-install.sh here (requires `pi` user + running `ratos` CLI).
set -ex

source /common.sh
install_cleanup_trap

apt-get update --allow-releaseinfo-change
# ratos-install.sh declares: python3-numpy python3-matplotlib curl (numpy often from Klipper module)
apt-get install -y --no-install-recommends python3-matplotlib curl

CONFIG_PARENT="$(dirname "${RATOS_CONFIGURATION_PATH}")"
mkdir -p "${CONFIG_PARENT}"

TMP_CLONE="$(mktemp -d)"
trap 'rm -rf "${TMP_CLONE}"' EXIT
# mktemp -d as root is mode 0700 root:root; git clone as pi cannot create the work tree inside it.
chown "${BASE_USER}:${BASE_USER}" "${TMP_CLONE}"

echo_green "Fetching RatOS-configurator (${RATOS_CONFIGURATOR_CONFIGURATION_BRANCH}) for configuration/ ..."
sudo -u "${BASE_USER}" git clone -b "${RATOS_CONFIGURATOR_CONFIGURATION_BRANCH}" --depth 1 \
    "${RATOS_CONFIGURATOR_REPO}" "${TMP_CLONE}/ratos-configurator"

if [[ ! -d "${TMP_CLONE}/ratos-configurator/configuration" ]]; then
    echo_red "Missing configuration/ in RatOS-configurator clone"
    exit 1
fi

rm -rf "${RATOS_CONFIGURATION_PATH}"
mkdir -p "${RATOS_CONFIGURATION_PATH}"
cp -a "${TMP_CLONE}/ratos-configurator/configuration/." "${RATOS_CONFIGURATION_PATH}/"

chown -R "${BASE_USER}:${BASE_USER}" "${RATOS_CONFIGURATION_PATH}"

# Align upstream ratos-update.sh with Bookworm + RavenOS PI5 (Pi 5 image stack)
RU="${RATOS_CONFIGURATION_PATH}/scripts/ratos-update.sh"
if [[ -f "${RU}" ]]; then
    KLIB="/home/${BASE_USER}/klippy-env/lib"
    if [[ -d "${KLIB}" ]]; then
        PYROOT="$(find "${KLIB}" -maxdepth 1 -mindepth 1 -type d -name 'python3.*' 2>/dev/null | head -n1)"
        if [[ -n "${PYROOT}" ]]; then
            PYDIR="$(basename "${PYROOT}")"
            sed -i "s/python3\\.9/${PYDIR}/g" "${RU}" || true
        fi
    fi
    # RavenOS PI5 ships Node 20 for RavenOS Configurator; do not downgrade to Node 18.
    sed -i 's/^ensure_node_18$/# &  # RavenOS PI5: Node 20 image/' "${RU}" || true
fi

echo_green "RatOS printer config tree installed at ${RATOS_CONFIGURATION_PATH} (from RatOS-configurator configuration/)"
