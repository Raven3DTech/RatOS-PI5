# R3DTOS PI5 — CustomPiOS master config (RatOS v2.1.x stack port for Raspberry Pi OS / Pi 5)
# ------------------------------------
# Module order matters; each module can depend on the previous.
# **prebase** runs `apt-get update` before **base** so `userconf-pi` upgrade in `base` does not fail on stale lists.
# **base** must run next: on modern Raspberry Pi OS there is no default login until `userconf.txt`
# is written on the boot partition (CustomPiOS `base` module). Without it, SSH shows
# "valid user has been set up" and `pi` / `raspberry` never work — same out-of-box UX as RatOS.
# klipper must come before moonraker, moonraker before mainsail,
# mainsail before ratos-configurator.
# timelapse must follow moonraker (links into moonraker/components).
# ratos-configuration must follow klipper (printer_data/config exists) and precede rpi_mcu (boards/rpi/firmware.config).
# network-support: WiFi firmware + NetworkManager (Bookworm); run early after base apt state is ready.
# hotspot: RatOS-derived autohotspot (hostapd + dnsmasq); after network-support. See BUILD.md vs NetworkManager.
# Modules (comma-separated; CustomPiOS v2 strips spaces, so use commas)
export MODULES="prebase,base,klipper,network-support,hotspot,ratos-configuration,dfu-util,moonraker,timelapse,mainsail,crowsnest,sonar,klipperscreen,rpi_mcu,ratos-configurator"

# Board: raspberrypiarm64 = RPi OS Lite arm64 (Pi 4 / Pi 5)
export BASE_BOARD="raspberrypiarm64"

# Board-specific settings for Raspberry Pi OS
export BASE_ARCH="arm64"
export BASE_IMAGE_RASPBIAN="yes"
export BASE_ROOT_PARTITION="2"
export BASE_BOOT_PARTITION="1"
export BASE_BOOT_MOUNT_PATH="boot"
# Extra MiB for root partition (CustomPiOS enlarge_ext). Stack is heavy: Klipper + Moonraker +
# KlipperScreen (PyGObject/venv) + crowsnest (camera-streamer build) + ratos-configurator (pnpm ~1k packages).
# 6000 MiB was enough for Bookworm-only; current Pi OS lite arm64 (trixie) + full module set can hit ENOSPC during pnpm install.
export BASE_IMAGE_ENLARGEROOT="14000"

# CustomPiOS `modules/base/config` runs `[ -n "$BASE_ZIP_IMG" ] || BASE_ZIP_IMG=$(ls … $BASE_IMAGE_PATH …)`.
# If BASE_ZIP_IMG is unset (e.g. sudo env not forwarded), that ls can return empty and the whole build
# aborts with "could not find image". Default matches `make download-image` → `src/image/…`.
export BASE_IMAGE_PATH="${DIST_PATH}/image"
[ -n "$BASE_ZIP_IMG" ] || export BASE_ZIP_IMG="${BASE_IMAGE_PATH}/raspios_lite_arm64_latest.img.xz"

# Distro metadata (CustomPiOS `base` end_chroot writes hostname + /etc/<dist>_version)
export DIST_NAME="R3DTOS-PI5"
export DIST_VERSION="1.0.0"

# Base system settings
export BASE_USER=pi
export BASE_USER_PASSWORD=raspberry
export BASE_HOSTNAME=r3dtospi5
export BASE_OVERRIDE_HOSTNAME="${BASE_HOSTNAME}"

# Timezone
export BASE_TIMEZONE="Australia/Sydney"

# Locale
export BASE_LOCALE="en_AU.UTF-8"

# Keyboard
export BASE_KEYBOARD_LAYOUT="us"

# Do not set BASE_CONFIG_TIMEZONE / LOCALE / KEYBOARD here: CustomPiOS `base` runs
# raspi-config nonint before other modules' `apt-get update`, and locale-gen for
# e.g. en_AU.UTF-8 often fails the chroot on GitHub Actions. Defaults leave raspi-config
# skips; first-boot / manual raspi-config can still apply BASE_* preferences on the Pi.

# Enable SSH on first boot (empty file on boot partition + sshd tweaks — variable is BASE_SSH_ENABLE in CustomPiOS)
export BASE_SSH_ENABLE=yes

# Image compression (xz level 6: balance of size vs speed)
export COMPRESS_IMAGE=1
export COMPRESSION_LEVEL=6
