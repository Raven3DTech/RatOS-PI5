# Line endings: CustomPiOS runs bash/chroot on Linux. CRLF breaks `source`, shebangs,
# sudoers (visudo), systemd units, and nginx helpers — long CI rebuilds for a tiny fix.
# Keep these paths LF on checkout (especially on Windows).

src/config text eol=lf
Makefile text eol=lf
scripts/** text eol=lf

# Every module: chroot scripts, configs, and unpacked filesystem trees
src/modules/**/start_chroot_script text eol=lf
src/modules/**/end_chroot_script text eol=lf
src/modules/**/config text eol=lf
src/modules/**/filesystem/** text eol=lf

# CI + docs
.github/** text eol=lf
*.md text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Images (do not force LF — corrupts PNG/WebP)
img/** binary
src/modules/**/filesystem/branding/** binary
